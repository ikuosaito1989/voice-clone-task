    "def main():\n",
    "    token = login()\n",
    "    items = get_pending_items(token)\n",
    "\n",
    "    if not items:\n",
    "        print(\"pending は 0 件です\")\n",
    "        return\n",
    "\n",
    "    downloaded_files = []\n",
    "\n",
    "    for _ in range(10):\n",
    "        for item in items:\n",
    "            voice_clone_id = item[\"id\"]\n",
    "            file_name = item.get(\"fileName\")\n",
    "    \n",
    "            print(f\"downloading id={voice_clone_id} ...\")\n",
    "            token = login()\n",
    "            output_path = download_reference_audio(token, voice_clone_id, file_name)\n",
    "            print(f\"saved: {output_path}\")\n",
    "    \n",
    "            # 音声生成\n",
    "            output_file = generate_qwen_voice(\n",
    "                text=\"こんにちは、さいとういくおです。本日はこの音声をお聞きいただき、ありがとうございます。この録音では、私の声の特徴を正確に伝えるため、自然なスピードと明瞭な発音を心がけています。今日はとても穏やかな一日で、気持ちよく過ごしています。これからも皆さまのお役に立てるサービスを提供していきたいと思いますので、どうぞよろしくお願いいたします。\",\n",
    "                ref_audio_path=str(output_path),\n",
    "                ref_text=\"こんにちわ、さいとういくおです。本日はご利用頂きありがとうございます。これからもどうぞよろしくお願いします。\",\n",
    "                output_path=\"/kaggle/working/qwen_cpu_test.wav\",\n",
    "            )\n",
    "            \n",
    "            print(\"生成されたファイル:\", output_file)\n",
    "    \n",
    "            downloaded_files.append(str(output_path))\n",
    "\n",
    "    print(\"\\n完了\")\n",
    "    print(\"downloaded files:\")\n",
    "    for path in downloaded_files:\n",
    "        print(path)\n",
    "\n",
    "\n",
    "main()"
   ]
  }
